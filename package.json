{
  "name": "crimegpt",
  "private": true,
  "version": "1.0.0",
  "description": "AI-Powered Police Documentation Platform",
  "author": "CrimeGPT Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --win",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.crimegpt.app",
    "productName": "CrimeGPT",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "database/",
        "to": "database/",
        "filter": ["*.json"]
      },
      {
        "from": "data/",
        "to": "data/",
        "filter": ["*.txt"]
      },
      {
        "from": "installer/OllamaSetup.exe",
        "to": "installer/OllamaSetup.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo1.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CrimeGPT",
      "installerIcon": "public/logo1.ico",
      "uninstallerIcon": "public/logo1.ico"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  }
}